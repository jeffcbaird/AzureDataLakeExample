{
  "name": "lakehouse-model",
  "compatibilityLevel": 1500,
  "model": {
    "culture": "en-US",
    "dataSources": [
      {
        "type": "structured",
        "name": "SynapseServerless",
        "description": "Synapse Analytics Serverless SQL endpoint — connects via the business views in sql/serverless/views/.",
        "connectionDetails": {
          "protocol": "tds",
          "address": {
            "server": "syn-lakehouse-dev-ondemand.sql.azuresynapse.net",
            "database": "gold"
          }
        },
        "credential": {
          "AuthenticationKind": "ServicePrincipal",
          "tenantId": "",
          "clientId": "",
          "clientSecret": ""
        }
      }
    ],
    "tables": [
      {
        "name": "fact_orders",
        "description": "Order fact table — 7-day rolling replaceWhere window. Connected to v_fact_orders Serverless view.",
        "columns": [
          { "name": "order_id",       "dataType": "string",   "sourceColumn": "order_id" },
          { "name": "customer_id",    "dataType": "string",   "sourceColumn": "customer_id" },
          { "name": "product_id",     "dataType": "string",   "sourceColumn": "product_id" },
          { "name": "product_sku",    "dataType": "string",   "sourceColumn": "product_sku" },
          { "name": "product_name",   "dataType": "string",   "sourceColumn": "product_name" },
          { "name": "product_category","dataType": "string",  "sourceColumn": "product_category" },
          { "name": "quantity",       "dataType": "int64",    "sourceColumn": "quantity" },
          { "name": "unit_price",     "dataType": "double",   "sourceColumn": "unit_price" },
          { "name": "amount",         "dataType": "double",   "sourceColumn": "amount" },
          { "name": "status",         "dataType": "string",   "sourceColumn": "status" },
          { "name": "order_date",     "dataType": "dateTime", "sourceColumn": "order_date",
            "formatString": "yyyy-MM-dd" },
          { "name": "_date",          "dataType": "string",   "sourceColumn": "_date",
            "isHidden": true }
        ],
        "measures": [
          {
            "name": "Total Revenue",
            "expression": "SUM(fact_orders[amount])",
            "formatString": "#,##0.00",
            "description": "Sum of order amounts."
          },
          {
            "name": "Order Count",
            "expression": "DISTINCTCOUNT(fact_orders[order_id])",
            "formatString": "#,##0",
            "description": "Count of distinct orders."
          },
          {
            "name": "Avg Order Value",
            "expression": "DIVIDE([Total Revenue], [Order Count])",
            "formatString": "#,##0.00",
            "description": "Average revenue per order."
          },
          {
            "name": "Units Sold",
            "expression": "SUM(fact_orders[quantity])",
            "formatString": "#,##0"
          }
        ],
        "partitions": [
          {
            "name": "fact_orders-default",
            "mode": "directQuery",
            "source": {
              "type": "m",
              "expression": [
                "let",
                "    Source = SynapseServerless,",
                "    Data   = Source{[Schema=\"gold\",Item=\"v_fact_orders\"]}[Data]",
                "in  Data"
              ]
            }
          }
        ]
      },
      {
        "name": "dim_date",
        "description": "Calculated date dimension — generated in-memory, no Serverless query required.",
        "columns": [
          { "name": "Date",        "dataType": "dateTime", "sourceColumn": "Date",
            "formatString": "yyyy-MM-dd" },
          { "name": "Year",        "dataType": "int64",    "sourceColumn": "Year" },
          { "name": "Quarter",     "dataType": "int64",    "sourceColumn": "Quarter" },
          { "name": "Month",       "dataType": "int64",    "sourceColumn": "Month" },
          { "name": "MonthName",   "dataType": "string",   "sourceColumn": "MonthName" },
          { "name": "Week",        "dataType": "int64",    "sourceColumn": "Week" },
          { "name": "DayOfWeek",   "dataType": "int64",    "sourceColumn": "DayOfWeek" },
          { "name": "IsWeekend",   "dataType": "boolean",  "sourceColumn": "IsWeekend" }
        ],
        "partitions": [
          {
            "name": "dim_date-calculated",
            "mode": "import",
            "source": {
              "type": "calculated",
              "expression": [
                "CALENDAR(DATE(2020,1,1), DATE(2030,12,31))"
              ]
            }
          }
        ],
        "calculatedColumns": [
          { "name": "Year",      "expression": "YEAR([Date])" },
          { "name": "Quarter",   "expression": "QUARTER([Date])" },
          { "name": "Month",     "expression": "MONTH([Date])" },
          { "name": "MonthName", "expression": "FORMAT([Date],\"MMMM\")" },
          { "name": "Week",      "expression": "WEEKNUM([Date])" },
          { "name": "DayOfWeek", "expression": "WEEKDAY([Date],2)" },
          { "name": "IsWeekend", "expression": "IF(WEEKDAY([Date],2)>=6, TRUE(), FALSE())" }
        ]
      },
      {
        "name": "daily_revenue_summary",
        "description": "Pre-aggregated daily revenue KPIs.",
        "columns": [
          { "name": "order_date",         "dataType": "dateTime", "sourceColumn": "order_date",
            "formatString": "yyyy-MM-dd" },
          { "name": "total_revenue",      "dataType": "double",   "sourceColumn": "total_revenue" },
          { "name": "order_count",        "dataType": "int64",    "sourceColumn": "order_count" },
          { "name": "avg_order_value",    "dataType": "double",   "sourceColumn": "avg_order_value" },
          { "name": "distinct_customers", "dataType": "int64",    "sourceColumn": "distinct_customers" },
          { "name": "revenue_7d_avg",     "dataType": "double",   "sourceColumn": "revenue_7d_avg" }
        ],
        "measures": [
          {
            "name": "Revenue 7d Avg",
            "expression": "AVERAGE(daily_revenue_summary[revenue_7d_avg])",
            "formatString": "#,##0.00"
          }
        ],
        "partitions": [
          {
            "name": "daily_revenue_summary-default",
            "mode": "directQuery",
            "source": {
              "type": "m",
              "expression": [
                "let",
                "    Source = SynapseServerless,",
                "    Data   = Source{[Schema=\"gold\",Item=\"v_daily_revenue_summary\"]}[Data]",
                "in  Data"
              ]
            }
          }
        ]
      }
    ],
    "relationships": [
      {
        "name": "fact_orders_date",
        "fromTable": "fact_orders",
        "fromColumn": "order_date",
        "toTable": "dim_date",
        "toColumn": "Date"
      }
    ],
    "roles": [
      {
        "name": "DataReader",
        "description": "Read-only access to all Gold tables. Assigned to Power BI service principal.",
        "modelPermission": "read",
        "members": []
      },
      {
        "name": "RegionalAnalyst",
        "description": "Row-level security: analyst sees only their own region's data.",
        "modelPermission": "read",
        "tablePermissions": [
          {
            "name": "fact_orders",
            "filterExpression": "fact_orders[status] <> \"cancelled\""
          }
        ],
        "members": []
      }
    ],
    "annotations": [
      { "name": "ClientCompatibilityLevel", "value": "600" }
    ]
  }
}

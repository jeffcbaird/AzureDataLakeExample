{
    "name": "canary_ftp_health",
    "properties": {
        "description": "15-minute connectivity ping for all FTP/SFTP sources. Calls the canary_ftp_health HTTP-triggered function (ingestion/ftp/canary.py) which connects to each host and lists the inbox directory, returning a per-source status map.",
        "activities": [
            {
                "name": "PingFtpSources",
                "type": "AzureFunctionActivity",
                "dependsOn": [],
                "userProperties": [],
                "typeProperties": {
                    "functionName": "canary_ftp_health",
                    "method": "POST",
                    "headers": {
                        "Content-Type": "application/json"
                    },
                    "body": "{}"
                },
                "linkedServiceName": {
                    "referenceName": "ls-functions-dev",
                    "type": "LinkedServiceReference"
                },
                "policy": {
                    "timeout": "0.00:05:00",
                    "retry": 0,
                    "retryIntervalInSeconds": 30,
                    "secureOutput": false,
                    "secureInput": false
                }
            }
        ],
        "annotations": []
    }
}

# Copy to .env for local development. No Azure credentials needed.
ENV=local
LOG_LEVEL=INFO

# Local data paths (resolved automatically by settings.py when ENV=local)
LOCAL_DATA_ROOT=./data/local

# Azure settings — only needed when ENV=azure
# AZURE_SUBSCRIPTION_ID=
# ADLS_ACCOUNT_NAME=
# ADLS_BRONZE_PATH=abfss://bronze@<account>.dfs.core.windows.net
# ADLS_SILVER_PATH=abfss://silver@<account>.dfs.core.windows.net
# ADLS_GOLD_PATH=abfss://gold@<account>.dfs.core.windows.net
# ADLS_QUARANTINE_PATH=abfss://quarantine@<account>.dfs.core.windows.net
# KEY_VAULT_URL=https://<vault-name>.vault.azure.net/
